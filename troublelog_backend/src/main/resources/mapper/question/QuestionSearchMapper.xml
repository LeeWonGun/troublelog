<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.min.edu.question.mapper.QuestionSearchMapper">

    <!--
        검색 조건 공통 WHERE 절이다.

        teamId가 null이면 PUBLIC 전체 게시판을 검색하고,
        teamId가 있으면 해당 팀의 TEAM 질문을 검색한다.

        TEAM 질문의 팀원 권한 검증은 인증/팀 구조가 확정된 뒤
        Service 계층에서 currentUserId 기준으로 추가한다.
    -->
    <sql id="questionSearchWhere">
        FROM questions q
        WHERE q.delflag = 'N'

        <choose>
            <when test="teamId != null">
                AND q.visibility = 'TEAM'
                AND q.team_id = #{teamId}
            </when>
            <otherwise>
                AND q.visibility = 'PUBLIC'
            </otherwise>
        </choose>

        <if test="keyword != null and keyword != ''">
            AND (
            LOWER(q.title) LIKE CONCAT('%', LOWER(#{keyword}), '%')
            OR LOWER(q.content) LIKE CONCAT('%', LOWER(#{keyword}), '%')
            )
        </if>

        <if test="status != null and status != ''">
            AND q.status = #{status}
        </if>

        <if test="techStackIds != null and techStackIds.size() > 0">
            AND EXISTS (
            SELECT 1
            FROM question_tech_stacks qts
            WHERE qts.question_id = q.id
            AND qts.tech_stack_id IN
            <foreach collection="techStackIds" item="techStackId" open="(" separator="," close=")">
                #{techStackId}
            </foreach>
            )
        </if>
    </sql>

    <!--
        질문 검색 결과를 페이징 조회한다.

        sort:
        - LATEST 또는 latest: 최신순
        - POPULAR 또는 popular: 좋아요순 + 최신순
        - SOLVED / UNSOLVED는 Service에서 status 조건으로 변환한 뒤 최신순으로 조회한다.
    -->
    <select id="searchQuestions"
            resultType="com.min.edu.question.dto.response.QuestionSearchRow">

        SELECT
        q.id AS questionId,
        q.title AS title,
        q.writer_id AS writerId,
        NULL AS writerNickname,
        q.status AS status,
        q.visibility AS visibility,
        q.answer_count AS answerCount,
        q.like_count AS likeCount,
        q.view_count AS viewCount,
        q.created_at AS createdAt
        <include refid="questionSearchWhere"/>

        <choose>
            <when test="sort == 'POPULAR' or sort == 'popular'">
                ORDER BY q.like_count DESC, q.created_at DESC
            </when>
            <otherwise>
                ORDER BY q.created_at DESC
            </otherwise>
        </choose>

        LIMIT #{size} OFFSET #{offset}

    </select>

    <!--
        검색 조건에 맞는 전체 개수를 조회한다.
    -->
    <select id="countSearchQuestions" resultType="long">

        SELECT COUNT(*)
        <include refid="questionSearchWhere"/>

    </select>

</mapper>