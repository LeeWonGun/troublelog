# Copy this file to .env and fill in real secret values.
# .env is ignored by Git.

# MySQL container
MYSQL_PORT=3306
MYSQL_DATABASE=troublelog
MYSQL_USER=troublelog
MYSQL_PASSWORD=troublelog
MYSQL_ROOT_PASSWORD=root

# Backend container
BACKEND_PORT=8080

# JWT HttpOnly cookie auth
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-bytes
JWT_EXPIRATION_MS=86400000
# Use false only for local HTTP development. Use true when the backend is served over HTTPS.
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAME_SITE=Lax
CSRF_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH2_SUCCESS_REDIRECT_URI=http://localhost:5173

# Email
MAIL_PROVIDER=smtp
MAIL_FROM=
MAIL_ENABLED=true
MAIL_CODE_EXPIRATION_MINUTES=5

# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-google-app-password

# Resend email
RESEND_API_KEY=
